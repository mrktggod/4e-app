{
    "name": "4e-app",
    "homepage": "./",
    "scripts": {
        "build:css": "lessc styles/main.less styles.css && cleancss styles.css -o styles.min.css",
        "build:worker-assets": "node scripts/build-pages-whitelist.mjs",
        "build:vk-hosting": "npm run build:css && node scripts/build-vk-hosting.mjs",
        "check:cp1251-mojibake": "node scripts/check-cp1251-mojibake.mjs",
        "check:js-syntax": "node scripts/check-js-syntax.mjs",
        "check:pages-script-assets": "npm run build:worker-assets && node scripts/check-pages-script-assets.mjs",
        "check:ui-architecture": "node scripts/run-bash-script.mjs scripts/check-ui-architecture.sh",
        "check:portable-paths": "node scripts/run-bash-script.mjs scripts/check-portable-paths.sh",
        "smoke:home001": "node scripts/home-001-dashboard-smoke.mjs",
        "smoke:back019": "node scripts/back-019-task-card-smoke.mjs",
        "smoke:back055": "node scripts/back-055-notifications-smoke.mjs",
        "smoke:back065": "node scripts/back-065-task-title-normalization-smoke.mjs",
        "smoke:back066-vk": "node scripts/back-066-vk-task-intent-smoke.mjs",
        "smoke:back050": "node scripts/back-050-accessibility-smoke.mjs",
        "smoke:smart007": "node scripts/smart-007-memory-fixture-smoke.mjs",
        "smoke:chat-history40": "node scripts/chat-history-over-40-evidence.mjs",
        "smoke:privacy-surface": "node scripts/privacy-surface-smoke.mjs",
        "smoke:auth-avatar": "node scripts/auth-avatar-login-diagnose.mjs",
        "smoke:viral-share": "node scripts/viral-share-card-smoke.mjs",
        "smoke:back067-reminder": "node scripts/back-067-task-detail-reminder-smoke.mjs",
        "smoke:back068-tag-popup": "node scripts/back-068-task-detail-tag-popup-smoke.mjs",
        "smoke:back069-hero": "node scripts/back-069-task-detail-hero-overflow-smoke.mjs",
        "smoke:ask-action-preview": "node scripts/ask-action-preview-bem-smoke.mjs",
        "test:e2e": "playwright test",
        "test:e2e:web": "playwright test autotests/tests/web",
        "test:e2e:telegram": "playwright test autotests/tests/telegram-app",
        "test:e2e:vk": "playwright test autotests/tests/vk-app",
        "test:e2e:report": "playwright show-report",
        "load:smoke": "k6 run autotests/load/smoke-load.js",
        "qa:prebeta": "npm run check:js-syntax && npm run check:cp1251-mojibake && npm run check:portable-paths && npm run check:ui-architecture && npm run test:e2e && npm run smoke:home001 && npm run smoke:back050 && npm run smoke:back055 && npm run smoke:privacy-surface && npm run smoke:viral-share",
        "deploy:worker-assets": "npm run build:worker-assets && wrangler deploy",
        "deploy:vk-hosting": "npm run build:vk-hosting && vk-miniapps-deploy",
        "api-smoke": "node scripts/api-smoke.mjs",
        "watch:css": "lessc --watch styles/main.less styles.css"
    },
    "devDependencies": {
        "@playwright/test": "^1.61.1",
        "@vkontakte/vk-miniapps-deploy": "^1.0.2",
        "clean-css-cli": "^5.6.3",
        "less": "^4.6.7"
    }
}
